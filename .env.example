# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real secrets.
#
# Client-exposed (VITE_*) values are bundled into the browser build and are
# therefore public by design. Do NOT put server secrets behind a VITE_ prefix.

# --- Public, client-side (safe to ship in the bundle) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
VITE_OPENCAGE_KEY=your-opencage-geocoding-key

# --- Server-side secrets (NEVER prefix with VITE_, NEVER commit) ---
# Used only by Node import scripts / Edge Functions, not the browser.
DEEPSEEK_API_KEY=your-deepseek-api-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # set in Edge Function env, not here
